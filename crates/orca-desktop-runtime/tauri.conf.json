{
  "$schema": "../../ui/desktop/node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ORCA",
  "version": "0.1.0",
  "identifier": "dev.orca.desktop",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../../ui/desktop",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build --prefix ../../ui/desktop",
    "frontendDist": "../../ui/desktop/dist"
  },
  "app": {
    "windows": [
      {
        "title": "ORCA",
        "width": 1280,
        "height": 840,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
